# ==================== TRUTH LAYER - ENVIRONMENT CONFIGURATION ====================
# Week 1: Node Zero Setup

# ==================== DATABASE ====================
DATABASE_URL=postgresql://truth_user:truth_secure_password_change_me@localhost:5432/truth_layer
DATABASE_POOL_MIN=5
DATABASE_POOL_MAX=20

REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=truth:

CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_DATABASE=truth_analytics
CLICKHOUSE_USER=truth_user
CLICKHOUSE_PASSWORD=truth_analytics_password

# ==================== API SERVICE ====================
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRY=24h
ACCESS_TOKEN_SECRET=access_token_secret_change_me
REFRESH_TOKEN_SECRET=refresh_token_secret_change_me

# ==================== ZK ENGINE (RUST) ====================
ZK_ENGINE_URL=http://localhost:50051
ZK_ENGINE_GRPC_PORT=50051
ZK_ENGINE_METRICS_PORT=8001
PROVING_KEY_PATH=/app/keys/proving_key.bin
VERIFYING_KEY_PATH=/app/keys/verifying_key.bin
ZK_GPU_ENABLED=false  # Set to true if GPU available
ZK_BATCH_SIZE=10      # Batch proofs for efficiency
ZK_TIMEOUT_SECONDS=120

# ==================== BLOCKCHAIN / ARWEAVE ====================
ARWEAVE_NODE_URL=https://arweave.net
ARWEAVE_WALLET_PATH=/app/arweave-wallet.json
ARWEAVE_NETWORK_ID=mainnet  # mainnet or devnet
ARWEAVE_TX_CONFIRMATION_TIMEOUT=300  # seconds

SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_NETWORK=mainnet-beta  # mainnet-beta or devnet
SOLANA_WALLET_PATH=/app/solana-wallet.json

ETHEREUM_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/your-api-key
ETHEREUM_CHAIN_ID=1  # Mainnet

# ==================== IPFS ====================
IPFS_API_URL=http://localhost:5001
IPFS_GATEWAY_URL=https://ipfs.io/ipfs

# ==================== SECURITY ====================
CORS_ENABLED=true
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

API_KEY_REQUIRED=false  # Enable for production
ADMIN_API_KEY=admin_api_key_change_me

HSTS_MAX_AGE=31536000
HELMET_ENABLED=true

# ==================== FILE STORAGE ====================
STORAGE_TYPE=local  # local, s3, gcs
STORAGE_PATH=/tmp/truth-storage
MAX_FILE_SIZE_MB=500

# S3 Configuration
S3_BUCKET=truth-layer-media
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=your_aws_access_key
S3_SECRET_ACCESS_KEY=your_aws_secret_key

# ==================== BILLING / PAYMENTS ====================
STRIPE_API_KEY=pk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

PAYMENT_PROCESSOR=stripe  # stripe, coinbase, circle
USDC_CONTRACT_ADDRESS=0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48  # Ethereum mainnet

# ==================== MONITORING & LOGGING ====================
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
PROMETHEUS_METRICS_PATH=/metrics

ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX=truth-logs

LOG_FORMAT=json  # json or text
LOG_TRANSPORT=elasticsearch,console  # elasticsearch, console, file

DATADOG_ENABLED=false
DATADOG_API_KEY=your_datadog_api_key

# ==================== SMTP / EMAIL ====================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@truth-layer.com

# ==================== MISC ====================
NODE_ID=node-zero  # Unique identifier for this Truth Protocol node
NETWORK_MODE=standalone  # standalone, testnet, mainnet

# ==================== FEATURE FLAGS ====================
FEATURE_DEVICE_PKI=true
FEATURE_ZK_PROOFS=true
FEATURE_BLOCKCHAIN_ANCHOR=true
FEATURE_GPU_ACCELERATION=false
FEATURE_MULTI_CHAIN=true

# Logging
DEBUG=truth-layer:*
VERBOSE_LOGGING=false
