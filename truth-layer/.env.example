# Truth Layer API - Environment Configuration
# Copy to .env and update for production

# Database
DATABASE_URL=\"postgresql://truth_user:change_me_in_production@postgres:5432/truth_layer?schema=public\"
DIRECT_URL=\"\"  # Removed dependency

# Redis
REDIS_URL=\"redis://redis:6379\"

# Security - REQUIRED
API_KEYS=\"key1,key2,key3\"  # Comma-separated for X-API-Key guard
JWT_SECRET=\"your-super-secret-jwt-key-change-this\"
API_KEY_SECRET=\"your-api-key-hmac-secret\"

# App
NODE_ENV=\"development\"
PORT=3000
LOG_LEVEL=\"info\"

# ZK Engine
ZK_ENGINE_URL=\"http://zk-engine:50051\"

# Blockchain
ARWEAVE_NODE=\"https://arweave.net\"
SOLANA_RPC=\"https://api.devnet.solana.com\"

# Storage
STORAGE_PATH=\"./uploads\"
STORAGE_TYPE=\"local\"

# CORS
CORS_ORIGINS=\"http://localhost:3000,http://localhost:3001\"

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

