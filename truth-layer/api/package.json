    "@nestjs/core": "^10.2.10",
    "@nestjs/jwt": "^11.0.1",
    "@nestjs/microservices": "^10.2.10",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.2.10",
    "@nestjs/swagger": "^11.3.0",
    "@prisma/client": "^5.6.0",
    "axios": "^1.6.2",
    "bs58": "^5.0.0",
    "bullmq": "^5.17.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "ethers": "^6.9.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "joi": "^17.13.3",
    "libsodium-wrappers": "^0.7.11",
    "lodash": "^4.17.21",
    "multer": "^1.4.5-lts.1",
    "nest-winston": "^1.10.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.11.2",
    "prisma": "^5.6.0",
    "redis": "^4.6.11",
    "swagger-ui-express": "^5.0.1",
    "tweetnacl": "^1.0.3",
    "uuid": "^9.0.1",
