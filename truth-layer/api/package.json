{
  "name":"truth-layer-api",
  "version":"1.0.0",
  "description":"Universal Truth Layer - Device Registry & Verification API (Node Zero)",
  "author":"Truth Layer Team",
  "license":"Apache-2.0",
  "main":"dist/main.js",
  "scripts": {
    "dev":"nest start --watch",
    "start":"nest start",
    "build":"nest build",
    "format":"prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint":"eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test":"jest",
    "test:watch":"jest --watch",
    "test:cov":"jest --coverage",
    "test:integration":"jest --testPathPattern=integration",
    "db:migrate":"prisma migrate deploy",
    "db:generate":"prisma generate",
    "seed":"ts-node src/database/seed.ts",
    "types:check":"tsc --noEmit"
  },
  "dependencies": {
    "@nestjs/common":"^10.2.10",
    "@nestjs/core":"^10.2.10",
    "@nestjs/platform-express":"^10.2.10",
    "@nestjs/jwt":"^11.0.1",
    "@nestjs/passport":"^10.0.3",
    "@nestjs/config":"^3.1.1",
    "@nestjs/microservices":"^10.2.10",
    "@nestjs/bullmq":"^10.2.1",
    "@grpc/grpc-js":"^1.9.9",
    "@prisma/client":"^5.6.0",
    "prisma":"^5.6.0",
    "bullmq":"^5.17.1",
    "ioredis":"^5.3.2",
    "redis":"^4.6.11",
    "passport":"^0.7.0",
    "passport-jwt":"^4.0.1",
    "pg":"^8.11.2",
    "class-transformer":"^0.5.1",
    "class-validator":"^0.14.0",
    "helmet":"^7.1.0",
    "compression":"^1.7.4",
    "cors":"^2.8.5",
    "uuid":"^9.0.1",
    "axios":"^1.6.2",
    "lodash":"^4.17.21",
    "winston":"^3.11.0",
    "winston-daily-rotate-file":"^4.7.1",
    "ethers":"^6.9.0",
    "tweetnacl":"^1.0.3",
    "libsodium-wrappers":"^0.7.11",
    "bs58":"^5.0.0"
  },
  "devDependencies": {
    "@nestjs/cli":"^10.2.1",
    "@nestjs/schematics":"^10.0.3",
    "@nestjs/testing":"^10.2.10",
    "@types/node":"^20.9.0",
    "@types/jest":"^29.5.8",
    "@types/express":"^4.17.21",
    "@typescript-eslint/eslint-plugin":"^6.10.0",
    "@typescript-eslint/parser":"^6.10.0",
    "eslint":"^8.53.0",
    "prettier":"^3.1.0",
    "typescript":"^5.2.2",
    "jest":"^29.7.0",
    "ts-jest":"^29.1.1",
    "ts-loader":"^9.5.1",
    "ts-node":"^10.9.1",
    "supertest":"^6.3.3"
  },
  "engines": {
    "node":">=18.0.0",
    "npm":">=9.0.0"
  }
