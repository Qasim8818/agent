// ==================== TRUTH LAYER - PRISMA SCHEMA ====================
// Database models for PostgreSQL backend
// Generation: npx prisma migrate dev

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "@prisma/client"
}

// ==================== ENUMS ====================

enum DeviceStatus {
  ACTIVE
  SUSPENDED
  REVOKED
  TESTING
  PAUSED
}

enum DeviceType {
  ANDROID
  IOS
  WEB
  EMBEDDED
  HARDWARE_SIGNER
}

enum VerificationStatus {
  PENDING
  IN_PROGRESS
  VERIFIED
  UNVERIFIED
  FAILED
  FLAGGED
  EXPIRED
}

enum BlockchainStatus {
  PENDING
  CONFIRMED
  FAILED
  DISPUTED
}

enum RevokeReason {
  COMPROMISED
  LOST_DEVICE
  USER_REQUEST
  SECURITY_INCIDENT
  UNAUTHORIZED_ACCESS
  MALWARE_DETECTED
  SUSPICIOUS_ACTIVITY
}

// ==================== DEVICE REGISTRY ====================

model Device {
  // Identifiers
  device_id            String @id @default(uuid()) @db.Uuid
  tpm_serial           String @unique @db.Varchar(256)
  tpm_public_key       String @db.Text // EdDSA public key
  attestation_key      String @db.Text

  // Device Info
  device_name          String @db.Varchar(100)
  device_type          DeviceType
  os_version           String? @db.Varchar(50)
  app_version          String? @db.Varchar(50)
  kernel_version       String? @db.Varchar(50)
  manufacturer         String? @db.Varchar(50)
  model                String? @db.Varchar(50)

  // Security
  api_key_hash         String @unique @db.VarChar(64) // SHA-256 hash
  status               DeviceStatus @default(ACTIVE)
  verified_at          DateTime
  last_activity_at     DateTime @default(now()) @updatedAt
  
  // Registration tracking
  registration_ip      String @db.Varchar(45) // IPv4 or IPv6
  user_agent           String? @db.Text
  
  // Metadata
  metadata             Json? // Custom fields: { "secureBoot": true, "hwPufPresent": true }

  // Timestamps
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt
  revoked_at           DateTime?
  revoke_reason        RevokeReason?

  // Relations
  verifications        Verification[]
  media_uploads        MediaFile[]
  revocations          Revocation[]
  audit_logs           ApiAuditLog[]
  usage_records        UsageMeter[]

  @@index([tpm_serial])
  @@index([status])
  @@index([created_at])
  @@index([registration_ip])
}

// ==================== REVOCATION TABLE ====================

model Revocation {
  revocation_id        String @id @default(uuid()) @db.Uuid
  device_id            String @db.Uuid
  device               Device @relation(fields: [device_id], references: [device_id], onDelete: Cascade)
  
  reason               RevokeReason
  description          String? @db.Text
  initiated_by         String? // User ID or system
  
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt
  
  @@index([device_id])
  @@index([created_at])
}

// ==================== MEDIA FILE UPLOADS ====================

model MediaFile {
  media_id             String @id @default(uuid()) @db.Uuid
  device_id            String @db.Uuid
  device               Device @relation(fields: [device_id], references: [device_id], onDelete: Cascade)

  // File identifiers
  media_hash           String @unique @db.VarChar(64) // SHA-256
  file_name            String @db.Varchar(255)
  file_size            Int // In bytes
  file_type            String @db.Varchar(50) // image/jpeg, image/png, video/mp4
  
  // Storage
  storage_path         String @db.Text // S3 or local path
  ipfs_hash            String? @db.VarChar(68) // Qm...
  ipfs_status          VerificationStatus @default(PENDING)
  
  // Metadata
  captured_at          DateTime // When media was captured on device
  upload_location      String? // GPS: "37.7749,-122.4194"
  metadata             Json? // Camera settings, EXIF, etc.
  
  // Verification
  device_signature     String? @db.Text // EdDSA signature from device TPM
  signature_verified   Boolean @default(false)
  
  // Timeline
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt
  expired_at           DateTime?
  
  // Relations
  verifications        Verification[]
  blockchain_anchors   BlockchainAnchor[]
  
  @@index([device_id])
  @@index([media_hash])
  @@index([created_at])
  @@index([file_type])
}

// ==================== VERIFICATION RECORDS ====================

model Verification {
  verification_id      String @id @default(uuid()) @db.Uuid
  device_id            String @db.Uuid
  device               Device @relation(fields: [device_id], references: [device_id], onDelete: Cascade)
  
  media_id             String @db.Uuid
  media                MediaFile @relation(fields: [media_id], references: [media_id], onDelete: Cascade)

  // Proof generation
  status               VerificationStatus @default(PENDING)
  zk_proof             String? @db.Text // Groth16 proof
  proof_hash           String? @db.VarChar(64)
  proof_generation_time Int? // Milliseconds
  
  // Result
  authenticity_score   Float? // 0.0 to 1.0
  confidence_level     String? @db.Varchar(20) // HIGH, MEDIUM, LOW
  found_anomalies      String[]? // Array of detected issues
  
  // Blockchain
  blockchain_status    BlockchainStatus @default(PENDING)
  arweave_tx_id        String? @db.Varchar(43)
  solana_tx_signature  String? @db.Varchar(88)
  
  // Timeline
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt
  verification_at      DateTime?
  blockchain_confirmed_at DateTime?
  
  // Metadata
  ip_address           String? @db.Varchar(45)
  user_agent           String? @db.Text
  
  @@index([device_id])
  @@index([media_id])
  @@index([status])
  @@index([created_at])
  @@unique([verification_id, device_id, media_id])
}

// ==================== ZK PROOF JOBS ====================

model ZkProofJob {
  job_id               String @id @default(uuid()) @db.Uuid
  verification_id      String @db.Uuid
  
  // Job state
  status               VerificationStatus @default(PENDING)
  queue_position       Int? // Position in processing queue
  retry_count          Int @default(0)
  max_retries          Int @default(3)
  
  // Processing
  started_at           DateTime?
  completed_at         DateTime?
  duration_ms          Int?
  
  // Result
  proof_output         Json? // Raw proof circuit output
  error_message        String? @db.Text
  
  // Timestamps
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt
  
  @@index([status])
  @@index([created_at])
}

// ==================== BLOCKCHAIN ANCHORING ====================

model BlockchainAnchor {
  anchor_id            String @id @default(uuid()) @db.Uuid
  verification_id      String? @db.Uuid
  media_id             String @db.Uuid
  media                MediaFile @relation(fields: [media_id], references: [media_id], onDelete: Cascade)
  
  // Arweave
  arweave_tx_id        String? @db.VarChar(43) @unique
  arweave_status       BlockchainStatus @default(PENDING)
  arweave_confirmed_at DateTime?
  
  // Solana
  solana_tx_sig        String? @db.VarChar(88) @unique
  solana_status        BlockchainStatus @default(PENDING)
  solana_slot          Int?
  solana_confirmed_at  DateTime?
  
  // Ethereum L2
  ethereum_tx_hash     String? @db.VarChar(66)
  ethereum_status      BlockchainStatus @default(PENDING)
  ethereum_confirmed_at DateTime?
  
  // Data anchored
  anchored_data        Json // { "media_hash": "...", "proof_hash": "...", "timestamp": "..." }
  
  // Timeline
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt
  
  @@index([media_id])
  @@index([arweave_tx_id])
  @@index([solana_tx_sig])
  @@index([created_at])
}

// ==================== API AUDIT LOG ====================

model ApiAuditLog {
  log_id               String @id @default(uuid()) @db.Uuid
  device_id            String? @db.Uuid
  device               Device? @relation(fields: [device_id], references: [device_id], onDelete: SetNull)
  
  // Request
  endpoint             String @db.Varchar(255)
  method               String @db.Varchar(10)
  status_code          Int
  
  // Authentication
  api_key_used         String? @db.Varchar(64) // Last 64 chars hashed
  
  // Tracking
  ip_address           String @db.Varchar(45)
  user_agent           String? @db.Text
  request_id           String @db.Varchar(36)
  
  // Performance
  response_time_ms     Int
  
  // Error tracking
  error_message        String? @db.Text
  
  // Timestamp
  created_at           DateTime @default(now())
  
  @@index([device_id])
  @@index([endpoint])
  @@index([status_code])
  @@index([created_at])
}

// ==================== USAGE METERING (BILLING) ====================

model UsageMeter {
  meter_id             String @id @default(uuid()) @db.Uuid
  device_id            String @db.Uuid
  device               Device @relation(fields: [device_id], references: [device_id], onDelete: Cascade)
  
  // Metering units
  verifications_count  Int @default(0)
  storage_gb          Float @default(0.0)
  bandwidth_gb        Float @default(0.0)
  
  // Billing
  estimated_cost_usd  Float @default(0.0)
  
  // Period
  period_start         DateTime
  period_end           DateTime
  billing_status       String @default("PENDING") // PENDING, BILLED, PAID
  
  // Timestamps
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt
  
  @@index([device_id])
  @@index([period_start])
}
