// ==================== TRUTH LAYER - PRISMA SCHEMA ====================
// Database models for PostgreSQL backend
// ⚠️ NOTE: This schema MUST match db/schema.sql for consistency
// Do NOT modify without also updating db/schema.sql

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "@prisma/client"
}

// ==================== DEVICE REGISTRY ====================
// Stores all registered devices (phones, cameras, etc.)
model Device {
  id                BigInt    @id @default(autoincrement())
  device_id         String    @unique @db.VarChar(64)  // SHA-256 hash of public key
  public_key        Bytes     // EdDSA public key (32 bytes)

  device_type       String    @db.VarChar(32)    // 'android', 'ios', 'camera'
  manufacturer      String    @db.VarChar(128)
  model             String    @db.VarChar(128)
  os_version        String?   @db.VarChar(32)

  hardware_backed   Boolean   @default(true)    // Has TPM 2.0 / Secure Enclave
  attestation_token String?   @db.Text

  registered_at     DateTime  @default(now()) @db.Timestamptz()
  last_activity     DateTime  @default(now()) @db.Timestamptz()
  status            String    @default("ACTIVE") @db.VarChar(32)  // ACTIVE, REVOKED, SUSPENDED
  revoked_reason    String?   @db.Text
  revoked_at        DateTime? @db.Timestamptz()

  metadata          Json?

  // Relations
  media             MediaFile[]
  verifications     Verification[]
  revocations       Revocation[]

  @@index([status])
  @@index([device_id])
  @@map("devices")
}

// ==================== REVOCATION TABLE ====================

model Revocation {
  id                BigInt    @id @default(autoincrement())
  device_id         String    @db.VarChar(64)
  device            Device    @relation(fields: [device_id], references: [device_id], onDelete: Cascade)

  reason            String    @db.VarChar(256)
  revoked_by        String?   @db.VarChar(128)
  revoked_at        DateTime  @default(now()) @db.Timestamptz()
  evidence          String?   @db.Text

  @@index([device_id])
  @@index([revoked_at])
  @@map("revocations")
}

// ==================== MEDIA FILE UPLOADS ====================

model MediaFile {
  id                BigInt    @id @default(autoincrement())
  media_hash        String    @unique @db.VarChar(64)
  media_type        String    @db.VarChar(32)          // 'image/jpeg', 'video/mp4', etc.
  size_bytes        BigInt

  device_id         String    @db.VarChar(64)
  device            Device    @relation(fields: [device_id], references: [device_id], onDelete: Cascade)

  created_at        BigInt                             // Unix timestamp from device
  location          Json?                              // {latitude, longitude, accuracy}
  nonce             String    @db.VarChar(64)          // Prevent replay attacks

  signature         Bytes
  signature_valid   Boolean   @default(false)

  ipfs_hash         String?   @db.VarChar(64)
  arweave_tx        String?   @db.VarChar(64)

  uploaded_at       DateTime  @default(now()) @db.Timestamptz()
  verification_status String  @default("PENDING") @db.VarChar(32)  // PENDING, VERIFIED, FAILED

  metadata          Json?

  verifications     Verification[]

  @@index([media_hash])
  @@index([verification_status])
  @@index([device_id])
  @@index([created_at])
  @@map("media")
}

// ==================== VERIFICATION RECORDS ====================

model Verification {
  id                BigInt    @id @default(autoincrement())
  media_hash        String    @db.VarChar(64)
  device_id         String    @db.VarChar(64)

  media             MediaFile @relation(fields: [media_hash], references: [media_hash], onDelete: Cascade)
  device            Device    @relation(fields: [device_id], references: [device_id], onDelete: Cascade)

  // Signature verification
  signature_verified Boolean   @default(false)
  signature_verified_at DateTime? @db.Timestamptz()
  signature_error   String?   @db.Text

  // ZK proof generation
  zk_proof_job_id   String?   @db.Uuid
  zk_proof          Bytes?
  zk_proof_generated_at DateTime? @db.Timestamptz()
  zk_proof_error    String?   @db.Text

  // Blockchain anchor
  blockchain_tx     String?   @db.VarChar(128)
  blockchain_verified Boolean @default(false)
  blockchain_verified_at DateTime? @db.Timestamptz()

  // Final result
  overall_status    String    @default("PENDING") @db.VarChar(32)
  trust_score       Float     @default(0.0)
  expires_at        DateTime? @db.Timestamptz()

  verified_at       DateTime  @default(now()) @db.Timestamptz()
  verifying_node    String?   @db.VarChar(128)

  @@index([media_hash])
  @@index([overall_status])
  @@index([verified_at])
  @@index([zk_proof_job_id])
  @@map("verifications")
}

// ==================== ZK PROOF JOBS ====================

model ZkProofJob {
  id                String    @id @db.Uuid
  media_hash        String    @db.VarChar(64)
  device_id         String    @db.VarChar(64)

  status            String    @default("QUEUED") @db.VarChar(32)  // QUEUED, PROCESSING, COMPLETED, FAILED
  priority          Int       @default(5)

  created_at        DateTime  @default(now()) @db.Timestamptz()
  started_at        DateTime? @db.Timestamptz()
  completed_at      DateTime? @db.Timestamptz()

  proof_result      Bytes?
  error_message     String?   @db.Text

  processing_time_ms BigInt?
  gpu_used          Boolean   @default(false)

  @@index([status])
  @@index([created_at])
  @@index([priority])
  @@map("zk_proof_jobs")
}

// ==================== BLOCKCHAIN ANCHORS ====================

model BlockchainAnchor {
  id                BigInt    @id @default(autoincrement())
  media_hash        String    @db.VarChar(64)
  blockchain        String    @db.VarChar(32)   // 'arweave', 'solana', 'ethereum'
  transaction_hash  String    @db.VarChar(256)

  anchor_data       Json                           // Full anchor payload
  anchored_at       DateTime  @default(now()) @db.Timestamptz()
  confirmation_height Int?
  finalized         Boolean   @default(false)

  @@index([blockchain])
  @@index([anchored_at])
  @@map("blockchain_anchors")
}

// ==================== API AUDIT LOGS ====================

model ApiAuditLog {
  id                BigInt    @id @default(autoincrement())
  device_id         String    @db.VarChar(64)
  endpoint          String    @db.VarChar(256)
  method            String    @db.VarChar(8)
  status_code       Int
  response_time_ms  Int
  error             String?   @db.Text

  created_at        DateTime  @default(now()) @db.Timestamptz()

  @@index([device_id])
  @@index([created_at])
  @@map("api_audit_logs")
}
  
  // Error tracking
  error_message        String? @db.Text
  
  // Timestamp
  created_at           DateTime @default(now())
  
  @@index([device_id])
  @@index([endpoint])
  @@index([status_code])
  @@index([created_at])
}

// ==================== USAGE METERING (BILLING) ====================

model UsageMeter {
  meter_id             String @id @default(uuid()) @db.Uuid
  device_id            String @db.Uuid
  device               Device @relation(fields: [device_id], references: [device_id], onDelete: Cascade)
  
  // Metering units
  verifications_count  Int @default(0)
  storage_gb          Float @default(0.0)
  bandwidth_gb        Float @default(0.0)
  
  // Billing
  estimated_cost_usd  Float @default(0.0)
  
  // Period
  period_start         DateTime
  period_end           DateTime
  billing_status       String @default("PENDING") // PENDING, BILLED, PAID
  
  // Timestamps
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt
  
  @@index([device_id])
  @@index([period_start])
}
