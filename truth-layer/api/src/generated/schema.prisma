// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // Removed directUrl dependency
}

model Device {
  device_id        String       @id @db.VarChar(64)
  tpm_serial       String?      @unique @db.VarChar(128)
  name             String?      @db.VarChar(128)
  device_name      String?      @db.VarChar(128)
  device_type      String?      @db.VarChar(32) // ANDROID, IOS, LINUX, etc.
  os_version       String?      @db.VarChar(32)
  app_version      String?      @db.VarChar(32)
  tpm_public_key   String       @db.VarChar(256)
  api_key_hash     String?      @db.VarChar(64)
  registration_ip  String?      @db.VarChar(45) // IPv6 support
  user_agent       String?      @db.VarChar(512)
  attestation_key  String?      @db.VarChar(256)
  verified_at      DateTime?
  status           String?      @default("ACTIVE") @db.VarChar(32)
  metadata         Json?
  created_at       DateTime     @default(now())
  updated_at       DateTime     @updatedAt
  last_activity_at DateTime?    @updatedAt
  usage_meters     UsageMeter[]

  @@index([device_id])
  @@index([tpm_serial])
  @@index([tpm_public_key])
  @@index([status])
  @@index([last_activity_at])
  @@map("devices")
}

model MediaFile {
  media_id           String   @id @db.VarChar(64)
  device_id          String   @db.VarChar(64)
  media_type         String   @db.VarChar(64)
  file_name          String   @db.VarChar(256)
  file_hash          String   @unique @db.VarChar(128)
  ipfs_hash          String?
  file_size          BigInt
  storage_path       String?
  signature_verified Boolean  @default(true)
  uploaded_at        DateTime @default(now())

  @@index([device_id])
  @@index([file_hash])
  @@index([media_type])
  @@index([signature_verified])
  @@map("media_files")
}

model Verification {
  verification_id String    @id @db.VarChar(64)
  device_id       String    @db.VarChar(64)
  media_id        String?
  status          String    @db.VarChar(32)
  proof_data      String?
  created_at      DateTime  @default(now())
  completed_at    DateTime?

  @@index([device_id])
  @@index([media_id])
  @@index([status])
  @@map("verifications")
}

model ZKProofJob {
  proof_id         String    @id @db.VarChar(64)
  device_id        String    @db.VarChar(64)
  media_hash       String?   @db.VarChar(128)
  proof_type       String    @db.VarChar(64)
  attestation_data String?
  status           String    @default("pending") @db.VarChar(32)
  proof_data       Bytes?
  proof_hash       String?   @db.VarChar(128)
  completed_at     DateTime?
  error_message    String?
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  @@index([device_id])
  @@index([media_hash])
  @@index([status])
  @@index([proof_type])
  @@map("zk_proof_jobs")
}

model UsageMeter {
  id           String    @id @default(cuid())
  device_id    String    @db.VarChar(64)
  metric       String    @db.VarChar(64)
  value        BigInt    @default(0)
  period_start DateTime  @default(now())
  period_end   DateTime?
  device       Device    @relation(fields: [device_id], references: [device_id], onDelete: Cascade)

  @@unique([device_id, metric, period_start])
  @@index([device_id])
  @@index([metric])
  @@map("usage_meters")
}

model BlockchainAnchor {
  anchor_id      String   @id @db.VarChar(64)
  device_id      String   @db.VarChar(64)
  proof_id       String   @db.VarChar(64)
  proof_hash     String   @db.VarChar(128)
  arweave_tx_id  String?  @db.VarChar(64)
  arweave_status String?  @default("pending")
  solana_tx_sig  String?  @db.VarChar(88)
  solana_status  String?  @default("pending")
  anchored_at    DateTime @default(now())
  updated_at     DateTime @updatedAt

  @@index([device_id])
  @@index([proof_id])
  @@index([proof_hash])
  @@index([arweave_status])
  @@index([solana_status])
  @@map("blockchain_anchors")
}

model DeviceMedia {
  id          String   @id @default(cuid())
  device_id   String   @db.VarChar(64)
  file_path   String   @db.VarChar(512)
  hash        String   @db.VarChar(128)
  size        BigInt
  mime_type   String   @db.VarChar(64)
  uploaded_at DateTime @default(now())

  @@index([device_id])
  @@index([hash])
  @@map("device_media")
}

model MediaVerification {
  id          String   @id @default(cuid())
  device_id   String   @db.VarChar(64)
  media_hash  String   @unique @db.VarChar(128)
  signature   String   @db.VarChar(256)
  verified_at DateTime @default(now())
  metadata    Json?

  @@index([device_id])
  @@index([media_hash])
  @@map("media_verifications")
}

// Scalable indexes for 10M+ records
// All tables have proper UUID ids, indexes on FKs/statuses/timestamps
// Cascade deletes for data hygiene
// Json metadata for flexibility without schema changes
